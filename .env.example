# MiniFanzo — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── WooCommerce API ──────────────────────────────────────────────────────────
# Your WordPress/WooCommerce site URL (no trailing slash)
NEXT_PUBLIC_WC_URL=https://yourdomain.com

# WooCommerce REST API Consumer Key (from WooCommerce > Settings > Advanced > REST API)
# ⚠️  Server-side only — never prefix with NEXT_PUBLIC_
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WooCommerce REST API Consumer Secret
# ⚠️  Server-side only — never prefix with NEXT_PUBLIC_
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Site Config ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME=MiniFanzo
NEXT_PUBLIC_SITE_URL=https://minifanzo.com

# ── WhatsApp Support Number ──────────────────────────────────────────────────
# Format: country code + number (no + or spaces)
# Bangladesh example: 8801XXXXXXXXX
NEXT_PUBLIC_WHATSAPP_NO=8801700000000

# ── bKash Payment Gateway ────────────────────────────────────────────────────
# Get credentials from bKash merchant portal
# https://developer.bka.sh/
NEXT_PUBLIC_BKASH_APP_KEY=your_bkash_app_key
BKASH_APP_SECRET=your_bkash_app_secret
BKASH_USERNAME=your_bkash_username
BKASH_PASSWORD=your_bkash_password
# Sandbox mode: https://tokenized.sandbox.bka.sh/v1.2.0-beta/tokenized/checkout
# Production:   https://tokenized.pay.bka.sh/v1.2.0-beta/tokenized/checkout
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta/tokenized/checkout

# ── SSLCommerz Payment Gateway ───────────────────────────────────────────────
# Get credentials from SSLCommerz merchant panel
# https://developer.sslcommerz.com/
SSLCZ_STORE_ID=your_store_id
SSLCZ_STORE_PASSWORD=your_store_password
# Sandbox: true | Production: false
SSLCZ_IS_LIVE=false

# ── ISR / Webhook Revalidation ───────────────────────────────────────────────
# Secret token to protect /api/revalidate endpoint
# Generate with: openssl rand -hex 32
REVALIDATE_SECRET=your_random_secret_here

# ── Optional: Google Analytics ───────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
